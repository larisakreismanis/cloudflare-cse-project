{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "curl-redirect-worker",
	"main": "src/index.js",
	"compatibility_date": "2026-03-01",
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "larisakdev.com/*",
			"zone_name": "larisakdev.com"
		},
		{
			"pattern": "www.larisakdev.com/*",
			"zone_name": "larisakdev.com"
		}
	]
}